{
  "name": "webpack-mf-next-microfrontends",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:host": "pnpm --filter host run dev",
    "dev:home": "pnpm --filter home run dev",
    "dev:all": "turbo run dev --filter=host --filter=home",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.4.4"
  }
}
